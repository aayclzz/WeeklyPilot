# 蓝桥SaaS平台自动化周报系统 配置文件
# 复制此文件为 .env 并填入你的真实信息

# ========== 蓝桥平台账号 ==========
LANQIAO_USERNAME=你的手机号
LANQIAO_PASSWORD=你的密码

# ========== 蓝桥平台URL ==========
LANQIAO_BASE_URL=https://saas.lanqiao.cn
WEEKLY_URL=https://saas.lanqiao.cn/saas/lyzyjsxy-lqb/student/evaluation/weekly/write/

# ========== AI模型配置 ==========
# 预设模型（推荐，只需填写API Key即可）
# 可选值：deepseek / deepseek-coder / mimo / qwen / qwen-plus / glm / moonshot / baichuan / yi / openai
AI_PROVIDER=deepseek

# API密钥（必填）
OPENAI_API_KEY=你的API密钥

# 自定义配置（如果使用预设模型，以下两项可留空）
# 如需自定义，取消注释并填写
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat

# ========== 定时任务配置 ==========
SUBMIT_DAY=5
SUBMIT_HOUR=18

# ========== 浏览器配置 ==========
# 浏览器类型：auto（自动检测）/ edge / chrome / firefox
BROWSER_TYPE=auto
# 是否使用无头模式（True=不显示浏览器窗口）
HEADLESS=False
# ChromeDriver路径（仅Chrome需要，留空则自动下载）
CHROMEDRIVER_PATH=

# ========== 课程配置（可选） ==========
# 留空 = 自动从 SaaS 周报页面发现课程（推荐新手使用）
# 手动配置 = 填写课程 ID（从蓝桥课程 URL 中获取）
#
# 在蓝桥云课打开你的课程，URL 里的数字就是课程 ID
# 例如：https://www.lanqiao.cn/courses/61384/ 中的 61384
COURSE_IDS=
COURSE_NAMES=
#
# 如果要手动配置多门课程，参考下面的格式：
# COURSE_IDS=61384,12345
# COURSE_NAMES=数据库技术,Linux基础

# ========== 日志配置 ==========
LOG_LEVEL=INFO
